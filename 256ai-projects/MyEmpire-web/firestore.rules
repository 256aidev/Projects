rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Player saves — only the owner can read/write
    match /saves/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Leaderboard — anyone authenticated can read, only owner can write
    match /leaderboard/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Syndicates — anyone authenticated can read, only Cloud Functions can write
    match /syndicates/{syndicateId} {
      allow read: if request.auth != null;
      allow write: if false;

      match /members/{memberId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // Wars — anyone authenticated can read, only Cloud Functions can write
    match /wars/{warId} {
      allow read: if request.auth != null;
      allow write: if false;

      match /fights/{fightId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // Syndicate invites — authenticated can read their own, only Cloud Functions can write
    match /syndicate_invites/{inviteId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
